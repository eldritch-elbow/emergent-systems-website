---
const base = import.meta.env.BASE_URL;
---

<div class="sec" style="display:flex;gap:52px;align-items:center;padding-top:76px;padding-bottom:76px">
  <div style="flex:1.25">
    <p class="eyebrow">Medical Technology and Software Consultancy</p>
    <h1 class="h1">Bringing order to chaos in health technology <span
        style="color:var(--c-text-lead)">across science, AI, software, and regulation.</span></h1>
    <p class="lead">
      Helping digital health innovators cut through the complexity to realise the value of their
      ideas, attract investment, and make a real impact in healthcare by creating safe, secure,
      and scalable regulated products.
    </p>
    <div class="row" style="margin-top:30px">
      <a class="btn btn-navy" href={`${base}#services`}>See services</a>
      <a class="btn btn-ocoral" href={`${base}#contact`}>Book a call →</a>
    </div>
  </div>
  <div style="flex:1">
    <div
      style="position:relative;height:300px;border-radius:var(--radius-card-lg);overflow:hidden;box-shadow:var(--shadow-hero)"
    >
      <canvas
        id="heroField"
        role="img"
        aria-label="Order, waiting to be uncovered in apparent chaos — a network crystallising out of a chaotic cloud"
        style="display:block;width:100%;height:100%;background:#1d2333"></canvas>
    </div>
  </div>
</div>

<script>
  import { HeroCanvas } from '../scripts/heroCanvas';

  const canvas = document.getElementById('heroField');
  if (canvas instanceof HTMLCanvasElement) {
    new HeroCanvas(canvas);
  }
</script>
