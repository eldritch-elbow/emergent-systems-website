---
const base = import.meta.env.BASE_URL;
---

<div
  class="sec about-row"
  id="about"
  style="display:flex;gap:44px;align-items:flex-start;background:var(--c-band);border-top:1px solid var(--c-band-border);border-bottom:1px solid var(--c-band-border)"
>
  <img
    src={`${base}uploads/james-siddle-headshot.jpg`}
    alt="James Siddle"
    style="width:150px;height:150px;border-radius:50%;flex:none;object-fit:cover"
  />
  <div style="flex:1">
    <p class="eyebrow">About</p>
    <h2 class="h2" style="margin-bottom:12px">Led by James Siddle</h2>
    <p class="body" style="max-width:640px">
      SaMD and clinical trials at Closed Loop Medicine; personalised-health platform architecture
      at Our Future Health; AI/ML product leadership for drug discovery at BenevolentAI; technical
      due diligence on a platform acquisition; MSc Software Engineering, University of Oxford.
    </p>
    <div class="row" style="margin-top:22px">
      <span class="chip">SaMD · MHRA · EU MDR fluency</span>
      <span class="chip">Patents &amp; publications</span>
      <span class="chip">Innovate UK grant track record</span>
    </div>
    <div class="row" style="margin-top:20px">
      <a class="btn btn-ocoral" href="https://jamessiddle.net/biblio.html" target="_blank" rel="noopener">Publications ↗</a>
      <a class="btn btn-ocoral" href="https://www.linkedin.com/in/jsiddle/" target="_blank" rel="noopener"
        >LinkedIn ↗</a
      >
      <a
        class="btn btn-ocoral"
        href="https://jamessiddle.net/assets/documents/JamesSiddle_CV.pdf"
        target="_blank"
        rel="noopener">CV ↗</a
      >
    </div>
    <p class="small" style="margin-top:14px">Full biography, publications and talks live on jamessiddle.net.</p>
  </div>
</div>
