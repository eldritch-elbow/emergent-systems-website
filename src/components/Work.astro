---
import { caseStudies } from '../content/caseStudies';

const base = import.meta.env.BASE_URL;
---

<div class="sec" id="work">
  <p class="eyebrow">Selected work</p>
  <h2 class="h2" style="margin-bottom:34px">Case studies</h2>
  <div class="grid3">
    {
      caseStudies.map((cs) => (
        <div style="background:var(--c-card-work);border:1px solid var(--c-card-border-work);border-radius:var(--radius-card);overflow:hidden">
          <img
            src={`${base}uploads/case-studies/${cs.image}`}
            alt={`${cs.cardTitle} case study`}
            style="display:block;width:100%;height:150px;object-fit:cover;border-bottom:1px solid var(--c-card-border-work)"
          />
          <div style="padding:22px">
            <div class="h3">{cs.cardTitle}</div>
            <p class="small" style="color:var(--c-coral-dark);margin:0 0 10px">{cs.client}</p>
            <p class="body">{cs.cardBody}</p>
            <a
              href={`${base}work/${cs.slug}/`}
              style="display:block;margin:14px 0 0;font:600 13px 'Space Grotesk';color:var(--c-coral);text-decoration:none"
            >
              Read case study →
            </a>
          </div>
        </div>
      ))
    }
  </div>
</div>
