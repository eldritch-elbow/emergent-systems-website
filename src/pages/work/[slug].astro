---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import { caseStudies, getNextCaseStudy, type CaseStudy } from '../../content/caseStudies';

export function getStaticPaths() {
  return caseStudies.map((cs) => ({ params: { slug: cs.slug }, props: { caseStudy: cs } }));
}

interface Props {
  caseStudy: CaseStudy;
}

const { caseStudy } = Astro.props;
const next = getNextCaseStudy(caseStudy.slug);
const base = import.meta.env.BASE_URL;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://emergentsystems.io/' },
    { '@type': 'ListItem', position: 2, name: 'Work', item: 'https://emergentsystems.io/#work' },
    {
      '@type': 'ListItem',
      position: 3,
      name: caseStudy.title,
      item: `https://emergentsystems.io/work/${caseStudy.slug}/`,
    },
  ],
};
---

<BaseLayout
  title={`${caseStudy.title} — Emergent Systems`}
  description={caseStudy.lead}
  image={!caseStudy.confidential ? `${base}uploads/case-studies/${caseStudy.heroImage}` : undefined}
  structuredData={[breadcrumbSchema]}
>
  <div class="page">
    <Nav />

    <div class="sec" style="padding-top:44px;padding-bottom:48px">
      <a class="back" href={`${base}#work`}>← Selected work</a>
      <p class="eyebrow" style="margin-top:22px">{caseStudy.eyebrow}</p>
      <h1 class="h1" style="max-width:820px">{caseStudy.title}</h1>
      <p class="lead" style="max-width:720px">{caseStudy.lead}</p>
      {
        !caseStudy.confidential && (
          <div class="meta">
            {caseStudy.meta.map((m) => (
              <div>
                <p class="k">{m.label}</p>
                <p class="v">{m.value}</p>
              </div>
            ))}
          </div>
        )
      }
    </div>

    {
      !caseStudy.confidential && (
        <div style="padding:0 84px 8px">
          <img
            src={`${base}uploads/case-studies/${caseStudy.heroImage}`}
            alt={caseStudy.heroImageLabel}
            style="display:block;width:100%;height:300px;object-fit:cover;border-radius:12px"
          />
        </div>
      )
    }

    {
      !caseStudy.confidential ? (
        <div class="sec" style="display:flex;gap:52px;align-items:flex-start;padding-top:44px">
          <div style="flex:1.7">
            {caseStudy.sections.map((section) => (
              <div style="margin-bottom:34px">
                <h2 class="h2">{section.heading}</h2>
                {section.paragraphs.map((p) => (
                  <p class="body" style="margin-bottom:14px">
                    {p}
                  </p>
                ))}
                {section.bullets?.map((b) => (
                  <div class="bullet">
                    <span class="d" />
                    <span class="t">{b}</span>
                  </div>
                ))}
              </div>
            ))}
            {caseStudy.note && <p class="note">{caseStudy.note}</p>}
          </div>

          <div style="flex:1;position:sticky;top:20px">
            <div class="side">
              <p class="k">At a glance</p>
              <p class="v" style="margin-bottom:20px">
                {caseStudy.atGlance}
              </p>
              <p class="k">Services drawn on</p>
              <div class="row" style="gap:8px;margin-bottom:20px">
                {caseStudy.servicesDrawn.map((s) => (
                  <span class="chip">{s}</span>
                ))}
              </div>
              <p class="k">Disciplines bridged</p>
              <p class="v">{caseStudy.disciplinesBridged}</p>
              <div style="border-top:1px solid #ddd3c2;margin-top:6px;padding-top:20px">
                <p class="h3">A similar challenge?</p>
                <p class="small" style="margin-bottom:16px">
                  Happy to talk through how this would apply to your product.
                </p>
                <a class="btn btn-navy" href={`${base}#contact`} style="display:block;text-align:center">
                  Book a call
                </a>
              </div>
            </div>
          </div>
        </div>
      ) : (
        <div class="sec" style="padding-top:12px;padding-bottom:64px;display:flex;gap:52px;align-items:flex-start">
          <div style="flex:1.7">
            <div class="conf">
              <span class="lock">
                <span class="b" />
                Confidential engagement
              </span>
              <h2 class="h2" style="margin-top:16px">
                Details available on request
              </h2>
              <p class="body" style="max-width:560px">
                This work is covered by confidentiality. I'm glad to talk through the approach, methods and what it
                delivered — and can share an anonymised summary suited to your context.
              </p>
              <div style="max-width:440px;margin:22px 0 26px">
                <div class="redact" style="width:92%" />
                <div class="redact" style="width:84%" />
                <div class="redact" style="width:70%" />
              </div>
              <div class="row">
                <a class="btn btn-coral" href={`${base}#contact`}>
                  Request a summary
                </a>
                <a class="btn btn-ocoral" href="mailto:emergentsystems.consulting@gmail.com">
                  Email me
                </a>
              </div>
            </div>
          </div>
          <div style="flex:1;position:sticky;top:20px">
            <div class="side">
              <p class="k">What can be shared</p>
              <p class="v" style="margin-bottom:20px">
                {caseStudy.whatCanBeShared}
              </p>
              <p class="k">Services drawn on</p>
              <div class="row" style="gap:8px">
                {caseStudy.servicesDrawn.map((s) => (
                  <span class="chip">{s}</span>
                ))}
              </div>
            </div>
          </div>
        </div>
      )
    }

    <div
      class="sec"
      style="background:var(--c-band);border-top:1px solid #ded9cf;display:flex;justify-content:space-between;align-items:center;gap:20px;flex-wrap:wrap"
    >
      <div>
        <p class="eyebrow">Next case study</p>
        <p class="h2" style="margin:0">
          {next.cardTitle} — {next.client} →
        </p>
      </div>
      <a class="btn btn-ocoral" href={`${base}#work`}>
        All work
      </a>
    </div>

    <div
      style="background:var(--c-ink);padding:40px 84px;display:flex;justify-content:space-between;align-items:center;gap:20px;flex-wrap:wrap"
    >
      <div class="brand" style="color:#fff;font-size:15px">
        <img src={`${base}uploads/emergent-systems-icon.png`} alt="" />
        <span>Emergent Systems</span>
      </div>
      <p class="small" style="color:#7b8194">emergentsystems.consulting@gmail.com · © 2026 Emergent Systems</p>
    </div>
  </div>
</BaseLayout>
